/**
 * Core Philosophy: This ruleset enforces a security model that strictly separates private user data from public and administrative data.
 * The primary goal is to ensure that users can only access their own information while allowing administrators global oversight and management capabilities.
 *
 * Data Structure: Most user-specific data (like orders, transactions, and notifications) is nested hierarchically under the /users/{userId} path. This path-based ownership is the primary mechanism for securing user data.
 * Top-level collections are used for data with different access patterns: `support_tickets` for collaborative user-admin interaction, `faqs` for public read-only content, and `loyalty_programs` for admin-only configurations.
 *
 * Key Security Decisions:
 * - User Data Privacy: All collections under `/users/{userId}` are strictly owned by that user. No other user can read or write to this data tree.
 * - Admin Roles: Administrative privileges are determined by the existence of a user's UID in the `/roles_admin` collection. This collection is not client-accessible and must be managed via a trusted server environment.
 * - No User Enumeration: Listing documents in the top-level `/users` collection is explicitly forbidden to protect user privacy.
 * - Public vs. Private: Data is segregated by structure. `/faqs` is public for reads, while all other data requires authentication. `support_tickets` allow a user to create a ticket, which can then be seen and managed by admins or the original user.
 *
 * Denormalization for Authorization: To ensure fast and secure rule evaluation, `userId` is denormalized onto documents like `SupportTicket`, `Order`, and `Transaction`. This avoids slow and costly `get()` calls in security rules, allowing for direct ownership checks against the document's own data.
 *
 * Structural Segregation: The ruleset leverages separate collections for data with different access controls. For example, private `/users/{userId}/notifications` are kept separate from the public `/faqs` collection, allowing for simple and performant security rules on each.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to abstract and simplify rule logic.
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user is an administrator.
     * Admin status is determined by the existence of their UID in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Verifies that a document already exists.
     * CRITICAL for all update and delete operations to prevent modifying non-existent data.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * @description
     * Stores user profile information. A user's own profile document is the root
     * for all their private, user-owned data.
     * @path /users/{userId}
     * @allow (create) A new user can create their own profile document.
     * @deny (get) An authenticated user `user_abc` CANNOT read the profile of `user_xyz`.
     * @principle Restricts access to a user's own data tree and enforces Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description
     * Stores a user's order history. Access is restricted to the user who owns the data.
     * @path /users/{userId}/orders/{orderId}
     * @allow (get, list) A user can read their own list of orders.
     * @deny (create) A user `user_abc` CANNOT create an order under `user_xyz`'s profile.
     * @principle Enforces path-based ownership for a user's private subcollections.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description
     * Stores a user's transaction history. Access is restricted to the user.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (get, list) A user can read their own list of transactions.
     * @deny (get) A user `user_abc` CANNOT read transactions belonging to `user_xyz`.
     * @principle Enforces path-based ownership for a user's private subcollections.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description
     * Stores notifications for a specific user. Only readable by the owner.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow (update) A user can update a notification, for example to mark it as read.
     * @deny (list) An admin CANNOT list notifications for a specific user to protect privacy.
     * @principle Enforces path-based ownership for a user's private subcollections.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description
     * Stores personalized product recommendations for a user. These are read-only for the user
     * and are expected to be written by a trusted backend service.
     * @path /users/{userId}/product_recommendations/{recommendationId}
     * @allow (get) A user can read their own product recommendations.
     * @deny (create, update, delete) A user CANNOT modify their own recommendations.
     * @principle Enforces read-only access for data managed by backend processes.
     */
    match /users/{userId}/product_recommendations/{recommendationId} {
      allow get, list: if isOwner(userId);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description
     * Stores support tickets created by users. Users can create and view their own tickets.
     * Admins have full read and write access to all tickets for management purposes.
     * @path /support_tickets/{ticketId}
     * @allow (create) An authenticated user can create a support ticket for themselves.
     * @deny (list) A regular user CANNOT list all support tickets in the system.
     * @principle Implements shared access between a document owner and an administrator.
     */
    match /support_tickets/{ticketId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if (isOwner(resource.data.userId) || isAdmin()) && isExistingDoc();
    }

    /**
     * @description
     * Stores frequently asked questions (FAQs). This data is public for anyone to read,
     * but can only be modified by an administrator.
     * @path /faqs/{faqId}
     * @allow (get, list) Any user, including unauthenticated users, can read FAQs.
     * @deny (create, update, delete) A non-admin user CANNOT modify the public FAQ content.
     * @principle Implements public read access with admin-only writes for global content.
     */
    match /faqs/{faqId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description
     * Stores loyalty program configurations. This is sensitive data that should only be
     * managed by administrators.
     * @path /loyalty_programs/{loyaltyProgramId}
     * @allow (get, list, create, update, delete) An admin can perform any operation.
     * @deny (get) A regular user CANNOT read the loyalty program configuration.
     * @principle Enforces strict admin-only access for system configuration data.
     */
    match /loyalty_programs/{loyaltyProgramId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description
     * A private collection used to grant admin roles. The existence of a document
     * with a user's UID as the ID means they are an admin. This collection MUST NOT
     * be accessible to any client.
     * @path /roles_admin/{userId}
     * @allow (any) No client operation is ever permitted on this collection.
     * @deny (any) All client requests (read, write) are rejected.
     * @principle Secures the role-management system by making it completely inaccessible from clients.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}