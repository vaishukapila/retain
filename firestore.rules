rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: This ruleset enforces a security model that combines strict user-ownership with role-based access control (RBAC) for administrative functions. The primary goal is to ensure that user data is private and can only be accessed by the user themselves, while global application settings are managed by a designated set of administrators.
     *
     * Data Structure: User-specific data (profiles, orders, notifications, etc.) is hierarchically organized under the `/users/{userId}` collection tree. This path-based structure simplifies ownership rules. Global data, such as `/loyalty_programs` and the highly sensitive `/toolkit_apis`, are top-level collections. Administrator roles are managed via a lookup collection, `/roles_admin`, which allows for efficient role checks without querying user documents.
     *
     * Key Security Decisions:
     * - User data is strictly private. A user can only access documents within their own `/users/{userId}` path. User enumeration via listing the top-level `/users` collection is explicitly forbidden.
     * - Administrator privileges are required for managing global configurations. Admin status is determined by the existence of a document in the `/roles_admin/{userId}` collection.
     * - Sensitive data, specifically the `/toolkit_apis` collection containing API keys, is accessible only to administrators for both reads and writes. This is the most secure posture.
     * - Publicly readable data, like `/loyalty_programs`, allows anonymous read access (`get`, `list`) but restricts all write operations to administrators.
     *
     * Denormalization for Authorization: The rules rely on the `/roles_admin` collection to quickly check for admin privileges using a single `exists()` call. This avoids needing to read a `role` field from a user's profile document, which would be slower and more complex. For user-owned subcollections, we enforce that a `userId` field is present on creation to link documents back to their owner, ensuring data integrity.
     *
     * Structural Segregation: The separation of private user data (`/users/{userId}/...`) from public (`/loyalty_programs`) and admin-only (`/toolkit_apis`) collections is a core design choice. This structure provides strong security boundaries and improves query performance by ensuring that queries do not need to filter mixed-privacy data.
     */

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user is a designated administrator.
     * Admin status is granted by the existence of a document in the `roles_admin` collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId from the path.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies that the document being operated on already exists in Firestore.
     * CRITICAL for safe update and delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * A convenience function that combines an ownership check with an existence check.
     * Used for all update and delete operations on user-owned documents.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * On create, validates that the incoming document's `userId` field matches the owner's UID.
     * This enforces relational integrity from the client.
     */
    function hasCorrectOwnerFieldOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * On update, ensures that the `userId` field cannot be changed.
     * This prevents re-assigning a document to another user.
     */
    function ownerFieldIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Manages user profile documents. Users can create their own profile, but can only read, update, or delete their own document. Listing all users is forbidden to prevent user enumeration.
     * @path /users/{userId}
     * @allow (create) An authenticated user with UID 'user123' creating their own document at `/users/user123`.
     * @deny (list) Any user, including admins, attempting to list the `/users` collection.
     * @deny (get) A user with UID 'user123' trying to read `/users/user456`.
     * @principle Enforces self-creation and strict ownership of a user's root document. Prevents data leakage through user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's orders. Only the user who owns the data tree can access their orders.
     * @path /users/{userId}/orders/{orderId}
     * @allow (get) An authenticated user with UID 'user123' reading an order at `/users/user123/orders/orderXYZ`.
     * @allow (list) An authenticated user with UID 'user123' listing all their orders at `/users/user123/orders`.
     * @deny (create) A user with UID 'user123' trying to create an order at `/users/user456/orders/orderABC`.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId}/orders/{orderId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerFieldOnCreate(userId);
      allow update: if isExistingOwner(userId) && ownerFieldIsImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's financial transactions. Only the user who owns the data tree can access their transactions.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (get) An authenticated user with UID 'user123' reading a transaction at `/users/user123/transactions/tx_XYZ`.
     * @deny (list) A user with UID 'user456' trying to list transactions at `/users/user123/transactions`.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerFieldOnCreate(userId);
      allow update: if isExistingOwner(userId) && ownerFieldIsImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's support tickets. Only the user who owns the data tree can access their tickets.
     * @path /users/{userId}/support_tickets/{supportTicketId}
     * @allow (get) An authenticated user with UID 'user123' reading a ticket at `/users/user123/support_tickets/ticket_XYZ`.
     * @deny (update) A user with UID 'user456' trying to update a ticket at `/users/user123/support_tickets/ticket_XYZ`.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId}/support_tickets/{supportTicketId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerFieldOnCreate(userId);
      allow update: if isExistingOwner(userId) && ownerFieldIsImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's notifications. Only the user who owns the data tree can access their notifications.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow (get) An authenticated user with UID 'user123' reading a notification at `/users/user123/notifications/notif_XYZ`.
     * @deny (delete) A user with UID 'user456' trying to delete a notification at `/users/user123/notifications/notif_XYZ`.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerFieldOnCreate(userId);
      allow update: if isExistingOwner(userId) && ownerFieldIsImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages loyalty program configurations. This data is considered public and can be read by anyone, but can only be modified by administrators.
     * @path /loyalty_programs/{loyaltyProgramId}
     * @allow (get) Any user, even unauthenticated, reading a loyalty program.
     * @allow (create) An administrator creating a new loyalty program.
     * @deny (update) A regular, non-admin user attempting to change the points-per-dollar value.
     * @principle Implements public-read access for global data while restricting mutations to privileged roles (Admins).
     */
    match /loyalty_programs/{loyaltyProgramId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Manages sensitive Toolkit API credentials. Access is strictly limited to administrators for all operations to prevent exposure of secret keys.
     * @path /toolkit_apis/{toolkitApiId}
     * @allow (get) An authenticated admin user reading an API key configuration.
     * @deny (get) Any non-admin user attempting to read an API key, even if they are signed in.
     * @deny (list) Any non-admin user attempting to list all API configurations.
     * @principle Enforces strict role-based access control (RBAC) for highly sensitive data. Defaults to the most secure posture (deny all).
     */
    match /toolkit_apis/{toolkitApiId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Manages which users have administrative privileges. Only existing admins can read, grant, or revoke admin status for other users.
     * @path /roles_admin/{userId}
     * @allow (create) An admin user adding a document for 'user456' to make them an admin.
     * @deny (delete) A regular user attempting to remove an admin's role document.
     * @deny (get) A regular user trying to check if another user is an admin.
     * @principle Secures the role management system itself, ensuring that only privileged users can modify permissions.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }
  }
}